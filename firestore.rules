// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: orders
// Document ID: auto-generated
// Fields:
//   - customerName: string (required) - Name of the customer
//   - customerPhone: string (required) - Phone number
//   - customerAddress: string (required) - Delivery address/notes
//   - items: list (required) - Array of order items
//   - totalPriceText: string (required) - Formatted total
//   - status: string (required) - [pending, cooking, completed, cancelled]
//   - timestamp: number (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "anhht4661@ut.edu.vn" && request.auth.token.email_verified == true);
    }

    function isValidOrder(data) {
      return data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.customerPhone is string && data.customerPhone.size() > 7 && data.customerPhone.size() < 20 &&
             data.customerAddress is string && data.customerAddress.size() > 0 && data.customerAddress.size() < 500 &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.totalPriceText is string && data.totalPriceText.size() < 50 &&
             data.status in ['pending', 'cooking', 'completed', 'cancelled'] &&
             data.timestamp is number;
    }

    match /orders/{orderId} {
      // Allow anyone to create an order (public ordering)
      allow create: if isValidOrder(request.resource.data);
      
      // Only admin can read, update or delete orders
      allow read, update, delete: if isAdmin();
    }
  }
}
